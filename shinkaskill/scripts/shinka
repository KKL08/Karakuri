#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { existsSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";

const scriptsDir = dirname(fileURLToPath(import.meta.url));
const skillDir = dirname(scriptsDir);
const cliPath = join(skillDir, "dist", "cli", "index.js");

if (!existsSync(cliPath)) {
  console.error("ShinkaSkill CLI 尚未构建。请在 shinkaskill 目录运行 npm install && npm run build。");
  process.exit(1);
}

const result = spawnSync(process.execPath, [cliPath, ...process.argv.slice(2)], {
  cwd: process.cwd(),
  env: process.env,
  stdio: "inherit",
});

if (result.error) {
  console.error(`ShinkaSkill CLI 启动失败：${result.error.message}`);
  process.exit(1);
}

process.exit(result.status ?? 1);
